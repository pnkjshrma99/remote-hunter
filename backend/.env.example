# Remote Hunter Backend — Environment Variables
# ==============================================
# Copy this to .env and fill in your values.
# Scrapers marked [OPTIONAL] will gracefully degrade if unset.

# --- Database ---
DATABASE_URL=sqlite:///./data/jobs.db
# For Render PostgreSQL:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Scraper Settings (all optional, have sensible defaults) ---
SCRAPE_INTERVAL_HOURS=5
SCRAPER_MAX_PARALLEL=30
REQUEST_DELAY_SECONDS=0.0
REQUEST_TIMEOUT_SECONDS=15
PIPELINE_SCRAPE_TIMEOUT=180
SCRAPER_TIMEOUT_SECONDS=45
DESCRIPTION_FETCH_ENABLED=false
DESCRIPTION_FETCH_WORKERS=5
DESCRIPTION_FETCH_DELAY=0.3

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.onrender.com

# --- Adzuna [OPTIONAL] — Free API, register at https://developer.adzuna.com ---
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=

# --- Greenhouse [OPTIONAL] — Falls back to 61 hardcoded boards ---
# GREENHOUSE_BOARD_TOKENS=gitlab,datadog,cloudflare

# --- LinkedIn [OPTIONAL] — Required for auth mode; guest mode often blocked ---
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=
# LINKEDIN_API_KEY=
# LINKEDIN_SEARCH_URLS=

# --- LLM Enrichment [OPTIONAL] — Disabled by default ---
# LLM_API_KEY=
# LLM_ENABLED=false
# LLM_MODEL=gpt-3.5-turbo
# LLM_ENRICHMENT_THRESHOLD=0.7

# --- Gemini AI Autofill [OPTIONAL] — For browser extension AI fill ---
# GEMINI_API_KEY=

# --- Cloudinary [OPTIONAL] — For CV storage ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Email/SMTP [OPTIONAL] — For job alerts ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# ALERT_EMAIL_TO=

# --- Slack [OPTIONAL] — For job alerts ---
# SLACK_WEBHOOK_URL=

# --- Auth (JWT + OAuth) ---
JWT_SECRET_KEY=your-secret-key-change-in-production
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
