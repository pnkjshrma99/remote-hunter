APP_NAME="Remote Job Hunter"
DEBUG=false
API_PREFIX=/api/v1

# SQLite for local development. Use postgresql+psycopg://user:pass@host:5432/db in production.
DATABASE_URL=sqlite:///./data/jobs.db

SCRAPE_ENABLED=true
SCRAPE_INTERVAL_HOURS=5
REQUEST_DELAY_SECONDS=1.5
REQUEST_TIMEOUT_SECONDS=30
# Add your deployed frontend origin here, e.g. https://remote-hunter.onrender.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production

# OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret

# Optional alerts.
ALERTS_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
SLACK_WEBHOOK_URL=

# Optional custom Greenhouse board tokens, comma-separated.
# Valid boards: gitlab, datadog, grafanalabs, cloudflare
GREENHOUSE_BOARD_TOKENS=gitlab,datadog,grafanalabs,cloudflare

# Optional public LinkedIn job search URLs, comma-separated. Leave empty unless you have URLs you are allowed to fetch.
LINKEDIN_SEARCH_URLS=

# Cloudinary Configuration for CV storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Frontend OAuth Configuration (for client-side OAuth flow)
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
